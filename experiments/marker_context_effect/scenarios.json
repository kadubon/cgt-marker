[
  {
    "id": "deadline_date_conflict",
    "title": "Deadline date conflict",
    "scenario_type": "conflicting_date",
    "report": "The project deadline is currently listed as 2026-06-01.",
    "claims": [
      {
        "subject": "project.deadline",
        "predicate": "date",
        "value": "2026-06-01",
        "source": "email",
        "metadata": {
          "quote": "The deadline is June 1.",
          "uri": "mail://deadline"
        }
      },
      {
        "subject": "project.deadline",
        "predicate": "date",
        "value": "2026-06-03",
        "source": "calendar",
        "metadata": {
          "quote": "The deadline is June 3.",
          "uri": "calendar://deadline"
        }
      }
    ],
    "expected": {
      "has_conflict": true,
      "requires_clarification": false,
      "values": ["2026-06-01", "2026-06-03"],
      "sources": ["email", "calendar"]
    }
  },
